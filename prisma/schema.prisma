datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum LobbyRole {
  OWNER
  MEMBER
}

enum LobbyMemberStatus {
  ACTIVE
  LEFT
}

enum DebtDirection {
  I_OWE
  OWES_ME
}

enum DebtStatus {
  OPEN
  SETTLED
  CANCELLED
}

enum DebtEventType {
  CREATE
  ADDITIONAL
  REPAYMENT
  SETTLE
  NOTE
}

enum DebtCategory {
  FAMILY
  FRIENDS
  WORK
  EMERGENCY
  BUSINESS
  OTHER
}

model User {
  id                   String      @id @default(cuid())
  auth0Id              String?     @unique
  email                String      @unique
  name                 String?
  accounts             Account[]
  transactions         Transaction[]
  lobbiesCreated       Lobby[]     @relation("LobbyCreator")
  lobbyMemberships     LobbyMember[]
  debtCases            DebtCase[]
  debtEventsRecorded   DebtEvent[] @relation("DebtEventActor")
  counterpartyDebtCases DebtCase[] @relation("DebtCounterpartyUser")
  createdAt            DateTime    @default(now())
}

model Account {
  id                String        @id @default(cuid())
  userId            String
  name              String
  balance           Int           @default(0)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  txns              Transaction[] @relation("SourceAccountTransactions")
  incomingTransfers Transaction[] @relation("DestinationAccountTransactions")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id                   String     @id @default(cuid())
  userId               String
  accountId            String
  toAccountId          String?
  type                 TransactionType
  category             String
  amount               Int
  description          String?
  date                 DateTime
  debtSettlementEvent  DebtEvent? @relation("DebtSettlementTransaction")
  id          String          @id @default(cuid())
  userId      String
  accountId   String
  toAccountId String?
  lobbyId     String?
  type        TransactionType
  category    String
  amount      Int
  description String?
  date        DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account  @relation("SourceAccountTransactions", fields: [accountId], references: [id], onDelete: Cascade)
  toAccount Account? @relation("DestinationAccountTransactions", fields: [toAccountId], references: [id], onDelete: SetNull)
  lobby     Lobby?   @relation(fields: [lobbyId], references: [id], onDelete: SetNull)
  lobbyTransferMirror LobbyTransaction? @relation("PocketTransferMirror")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([accountId, date])
  @@index([toAccountId, date])
  @@index([lobbyId, date])
}

model DebtCase {
  id                 String        @id @default(cuid())
  userId             String
  counterpartyUserId String?
  personName         String
  direction          DebtDirection
  category           DebtCategory  @default(OTHER)
  reason             String
  note               String?
  openedAt           DateTime
  dueDate            DateTime?
  status             DebtStatus    @default(OPEN)
  totalAmount        Int           @default(0)
  repaidAmount       Int           @default(0)
  remainingAmount    Int           @default(0)
  settledAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  counterpartyUser User?     @relation("DebtCounterpartyUser", fields: [counterpartyUserId], references: [id], onDelete: SetNull)
  events           DebtEvent[]

  @@index([userId, status, direction])
  @@index([userId, dueDate])
  @@index([userId, category])
  @@index([counterpartyUserId])
}

model DebtEvent {
  id                      String      @id @default(cuid())
  debtCaseId              String
  actorUserId             String?
  type                    DebtEventType
  amount                  Int         @default(0)
  note                    String?
  eventDate               DateTime
  settlementTransactionId String?     @unique
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  debtCase              DebtCase      @relation(fields: [debtCaseId], references: [id], onDelete: Cascade)
  actorUser             User?         @relation("DebtEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  settlementTransaction Transaction?  @relation("DebtSettlementTransaction", fields: [settlementTransactionId], references: [id], onDelete: SetNull)

  @@index([debtCaseId, eventDate])
  @@index([actorUserId])
}

model Lobby {
  id           String             @id @default(cuid())
  name         String
  description  String?
  balance      Int                @default(0)
  createdById  String
  createdBy    User               @relation("LobbyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  pocketTransfers Transaction[]
  members      LobbyMember[]
  transactions LobbyTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([createdById])
}

model LobbyMember {
  id           String             @id @default(cuid())
  lobbyId      String
  userId       String
  role         LobbyRole          @default(MEMBER)
  status       LobbyMemberStatus  @default(ACTIVE)
  joinedAt     DateTime           @default(now())
  lobby        Lobby              @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LobbyTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([lobbyId, userId])
  @@index([lobbyId])
  @@index([userId])
}

model LobbyTransaction {
  id                  String          @id @default(cuid())
  lobbyId             String
  memberId            String
  personalTransactionId String?       @unique
  type                TransactionType
  category            String
  amount              Int
  description         String?
  date                DateTime
  lobby               Lobby           @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  member              LobbyMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  personalTransaction Transaction?    @relation("PocketTransferMirror", fields: [personalTransactionId], references: [id], onDelete: SetNull)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([lobbyId, date])
  @@index([memberId])
}
